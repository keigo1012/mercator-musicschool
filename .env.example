NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Server only. Do not expose these with NEXT_PUBLIC_.
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="replace-with-escaped-private-key"

# Google Calendar API. Share the target calendar with the service account email.
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="replace-with-escaped-private-key"

# Resend contact form email.
RESEND_API_KEY=
RESEND_FROM_EMAIL=contact@mercator-musicschool.com
RESEND_FROM_NAME=メルカトル音楽教室
