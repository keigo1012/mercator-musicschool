{
  "name": "mercator-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build:cloudflare": "opennextjs-cloudflare build",
    "build:cloudflare:preview": "opennextjs-cloudflare build --env dependabot-preview",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "npm run build:cloudflare && opennextjs-cloudflare deploy",
    "deploy:dependabot-preview:built": "opennextjs-cloudflare deploy --env dependabot-preview",
    "deploy:dependabot-preview": "npm run build:cloudflare:preview && npm run deploy:dependabot-preview:built",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "firebase": "^12.15.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4.3.2",
    "typescript": "^5",
    "wrangler": "^4.107.0"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
